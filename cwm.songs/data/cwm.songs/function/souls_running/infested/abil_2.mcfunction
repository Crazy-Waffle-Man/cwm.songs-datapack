execute as @e[tag=cwm.infest_block] run function cwm.songs:util/place_on_ground
scoreboard objectives add cwm.random dummy
gamerule sendCommandFeedback false
execute as @e[tag=cwm.infest_block] store result score @s cwm.random run random value 1..5
gamerule sendCommandFeedback true
execute as @e[tag=cwm.infest_block,scores={cwm.random=5}] at @s run particle infested ~ ~ ~ 0.25 0.25 0.25 0 100 force
execute as @e[tag=cwm.infest_block,scores={cwm.random=5}] at @s run summon silverfish ~ ~ ~ {Health: 10}
gamerule doTileDrops false
execute as @e[type=silverfish] at @s run setblock ~ ~-1 ~ air destroy
gamerule doTileDrops true
kill @e[tag=cwm.infest_block]
scoreboard objectives remove cwm.random
scoreboard players set @s CD2 600